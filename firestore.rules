rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default catch-all security posture
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // 1. PRODUCTS COLLECTION
    match /products/{productId} {
      allow read: if true; // Public viewable
      allow create, update, delete: if isValidId(productId); // Open read/write to products for server broker
    }

    // 2. REQUESTS COLLECTION
    match /requests/{requestId} {
      allow read, write: if true; // Open read/write to requests for server broker and clients
    }
  }
}
