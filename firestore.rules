rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default catch-all security posture
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'maurya.rahul6820@gmail.com' && 
             request.auth.token.email_verified == true;
    }

    // 1. PRODUCTS COLLECTION
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin() && isValidId(productId);
      allow update: if (isAdmin() && isValidId(productId)) || (
        isValidId(productId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) &&
        request.resource.data.likes is number &&
        request.resource.data.likes >= 0
      );
    }

    // 2. REQUESTS COLLECTION
    match /requests/{requestId} {
      // Public users can submit request forms
      allow create: if isValidId(requestId) &&
                    request.resource.data.id == requestId &&
                    request.resource.data.customerName is string &&
                    request.resource.data.customerName.size() <= 100 &&
                    request.resource.data.phone is string &&
                    request.resource.data.phone.size() <= 30 &&
                    request.resource.data.email is string &&
                    request.resource.data.email.size() <= 100 &&
                    request.resource.data.village is string &&
                    request.resource.data.village.size() <= 100 &&
                    request.resource.data.productId is string &&
                    request.resource.data.productId.size() <= 128;
      
      // Only authorized Admins can view sheets, update status of delivery or delete logs
      allow read, update, delete: if isAdmin() && isValidId(requestId);
    }
  }
}
